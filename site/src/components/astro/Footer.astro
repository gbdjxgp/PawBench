---
import { type Locale, t } from '@/i18n';

interface Props { locale: Locale }
const { locale } = Astro.props;
---

<footer class="border-t border-slate-200 dark:border-slate-800 mt-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-slate-500 dark:text-slate-400">
    <div class="flex items-center gap-2">
      <span aria-hidden="true">🐾</span>
      <span>PawBench &middot; {t(locale, 'footer.builtBy')}</span>
    </div>
    <div class="flex items-center gap-3">
      <a href="https://github.com/agentscope-ai/pawbench" class="hover:text-slate-900 dark:hover:text-white">GitHub</a>
      <span>·</span>
      <span>{t(locale, 'footer.license')}</span>
    </div>
  </div>
</footer>
