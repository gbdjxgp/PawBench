---
import { type Locale, t } from '@/i18n';
import statsJson from '@/data/stats.json';

interface Props { locale: Locale }
const { locale } = Astro.props;

const stats = statsJson as { total: number; sources: Record<string, number>; capabilities: Record<string, number> };

const numbers = [
  { v: stats.total,                            k: 'hero.stats.tasks' },
  { v: Object.keys(stats.sources).length,      k: 'hero.stats.sources' },
  { v: 3,                                      k: 'hero.stats.harnesses' },
  { v: Object.keys(stats.capabilities).length, k: 'hero.stats.capabilities' },
];
---

<section class="relative overflow-hidden border-b border-slate-200 dark:border-slate-800">
  <div class="absolute inset-0 -z-10 opacity-[0.04] dark:opacity-[0.07]" aria-hidden="true">
    <div class="absolute inset-0" style="background-image: radial-gradient(circle at 20% 20%, #0f766e 0, transparent 40%), radial-gradient(circle at 80% 60%, #14b8a6 0, transparent 35%);"></div>
  </div>

  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 pt-10 pb-6 text-center">
    <div class="flex justify-center text-xs text-brand-700 dark:text-brand-300 font-medium mb-3">
      <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full bg-brand-50 dark:bg-brand-950/50 border border-brand-200 dark:border-brand-900">
        <span class="w-1.5 h-1.5 rounded-full bg-brand-500 animate-pulse"></span>
        v1.0 · {stats.total} tasks
      </span>
    </div>

    <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-slate-900 dark:text-white">
      <span class="text-brand-700 dark:text-brand-400">Paw</span><span>Bench</span>
    </h1>

    <p class="mt-2 text-base sm:text-lg text-slate-700 dark:text-slate-200 font-medium">
      {t(locale, 'site.tagline')}
    </p>

    <div class="mt-4 flex justify-center">
      <code class="inline-block text-xs sm:text-sm font-mono px-2 py-0.5 rounded bg-brand-50 dark:bg-brand-950/40 border border-brand-200 dark:border-brand-900 text-brand-800 dark:text-brand-200 whitespace-nowrap">
        {t(locale, 'hero.formula')}
      </code>
    </div>

    <p class="mt-3 text-sm text-slate-600 dark:text-slate-400">
      {t(locale, 'site.description')}
    </p>

    <div class="mt-5 flex flex-wrap justify-center items-baseline gap-x-3 gap-y-1 text-xs text-slate-500 dark:text-slate-500">
      {numbers.map(({ v, k }, i) => (
        <span class="inline-flex items-baseline gap-1">
          {i > 0 && <span class="text-slate-300 dark:text-slate-700" aria-hidden="true">·</span>}
          <span class="font-bold tabular-nums text-slate-700 dark:text-slate-300 text-sm">{v}</span>
          <span>{t(locale, k)}</span>
        </span>
      ))}
    </div>
  </div>
</section>
