---
import { type Locale, t, localizedPath } from '@/i18n';
import statsJson from '@/data/stats.json';

interface Props { locale: Locale }
const { locale } = Astro.props;

const stats = statsJson as { total: number; sources: Record<string, number>; capabilities: Record<string, number> };

const numbers = [
  { v: stats.total,                          k: 'hero.stats.tasks' },
  { v: Object.keys(stats.sources).length,    k: 'hero.stats.sources' },
  { v: 3,                                    k: 'hero.stats.harnesses' },
  { v: Object.keys(stats.capabilities).length, k: 'hero.stats.capabilities' },
];
---

<section class="relative overflow-hidden border-b border-slate-200 dark:border-slate-800">
  <div class="absolute inset-0 -z-10 opacity-[0.04] dark:opacity-[0.07]" aria-hidden="true">
    <div class="absolute inset-0" style="background-image: radial-gradient(circle at 20% 20%, #0f766e 0, transparent 40%), radial-gradient(circle at 80% 60%, #14b8a6 0, transparent 35%);"></div>
  </div>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-16 pb-12">
    <div class="flex items-center gap-2 text-xs text-brand-700 dark:text-brand-300 font-medium mb-4">
      <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full bg-brand-50 dark:bg-brand-950/50 border border-brand-200 dark:border-brand-900">
        <span class="w-1.5 h-1.5 rounded-full bg-brand-500 animate-pulse"></span>
        v1.0 · 150 tasks
      </span>
    </div>
    <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-slate-900 dark:text-white">
      <span class="text-brand-700 dark:text-brand-400">paw</span><span>bench</span>
    </h1>
    <p class="mt-3 text-lg text-slate-600 dark:text-slate-300 max-w-3xl">
      {t(locale, 'site.tagline')}
    </p>
    <p class="mt-2 text-sm text-slate-500 dark:text-slate-400 max-w-3xl">
      {t(locale, 'site.description')}
    </p>

    <div class="mt-6 flex flex-wrap gap-3">
      <a
        href={localizedPath(locale, '/tasks')}
        class="inline-flex items-center gap-1.5 px-4 py-2 rounded-md bg-brand-700 hover:bg-brand-800 text-white text-sm font-medium transition"
      >
        {t(locale, 'hero.cta.tasks')} →
      </a>
      <a
        href="https://github.com/agentscope-ai/pawbench"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-1.5 px-4 py-2 rounded-md border border-slate-200 dark:border-slate-700 text-slate-700 dark:text-slate-200 text-sm font-medium hover:bg-slate-50 dark:hover:bg-slate-900 transition"
      >
        {t(locale, 'hero.cta.github')}
      </a>
    </div>

    <div class="mt-10 grid grid-cols-2 sm:grid-cols-4 gap-3 max-w-3xl">
      {numbers.map(({ v, k }) => (
        <div class="rounded-lg border border-slate-200 dark:border-slate-800 px-4 py-3 bg-white dark:bg-slate-900/50">
          <div class="text-2xl font-bold tabular-nums text-slate-900 dark:text-white">{v}</div>
          <div class="text-xs text-slate-500 mt-0.5">{t(locale, k)}</div>
        </div>
      ))}
    </div>
  </div>
</section>
