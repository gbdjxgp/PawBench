---
interface Props {
  label: string;
  value: string;
  mono?: boolean;
}
const { label, value, mono } = Astro.props;
---
<div>
  <dt class="text-[10px] uppercase tracking-wider text-slate-400">{label}</dt>
  <dd class={`mt-0.5 ${mono ? 'font-mono text-xs' : 'text-sm'} text-slate-700 dark:text-slate-200 break-all`}>{value}</dd>
</div>
