---
import Base from '@/layouts/Base.astro';
import Hero from '@/components/astro/Hero.astro';
import HowItWorks from '@/components/astro/HowItWorks.astro';
import Citation from '@/components/astro/Citation.astro';
import MatrixTabs from '@/components/react/MatrixTabs.tsx';
import LeaderboardTable from '@/components/react/LeaderboardTable.tsx';
import leaderboardJson from '@/data/leaderboard.json';
import statsJson from '@/data/stats.json';
import { type Locale, t } from '@/i18n';
import type { LeaderboardData, StatsData } from '@/lib/types';

const locale: Locale = 'en';
const data = leaderboardJson as LeaderboardData;
const stats = statsJson as StatsData;

const matrixLabels = {
  title: t(locale, 'leaderboard.matrix.title'),
  empty: t(locale, 'leaderboard.matrix.empty'),
  avg: t(locale, 'leaderboard.matrix.avg'),
  delta: 'Δ',
  none: '—',
  textOnlyBadge: t(locale, 'leaderboard.matrix.textOnlyBadge'),
  textOnlyNote: t(locale, 'leaderboard.matrix.note'),
};

const totalTasks = stats.total ?? 0;
const textTasks = stats.modality?.text ?? 0;
const multiTasks = stats.modality?.multimodal ?? 0;

const matrixTabs = [
  {
    key: 'overall' as const,
    label: t(locale, 'matrix.tab.overall'),
    hint: t(locale, 'matrix.tab.overall.hint'),
    count: totalTasks,
  },
  {
    key: 'text' as const,
    label: t(locale, 'matrix.tab.text'),
    hint: t(locale, 'matrix.tab.text.hint'),
    count: textTasks,
  },
  {
    key: 'multimodal' as const,
    label: t(locale, 'matrix.tab.multimodal'),
    hint: t(locale, 'matrix.tab.multimodal.hint'),
    count: multiTasks,
  },
];

const matrixNotes = {
  text: t(locale, 'matrix.note.text'),
  multimodal: t(locale, 'matrix.note.multimodal'),
};

const tableLabels = {
  rank: t(locale, 'leaderboard.col.rank'),
  model: t(locale, 'leaderboard.col.model'),
  harness: t(locale, 'leaderboard.col.harness'),
  overall: t(locale, 'leaderboard.col.overall'),
  automated: t(locale, 'leaderboard.col.automated'),
  judge: t(locale, 'leaderboard.col.judge'),
  tasks: t(locale, 'leaderboard.col.tasks'),
  updated: t(locale, 'leaderboard.col.updated'),
};
---

<Base locale={locale} title={t(locale, 'leaderboard.title')}>
  <Hero locale={locale} />

  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-6 pb-12 space-y-10">
    <div>
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">{t(locale, 'leaderboard.matrix.title')}</h2>
      <div class="mt-3">
        <MatrixTabs client:load data={data} tabs={matrixTabs} matrixLabels={matrixLabels} notes={matrixNotes} />
      </div>
    </div>

    <div>
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">{t(locale, 'leaderboard.title')}</h2>
      <div class="mt-4">
        <LeaderboardTable client:load data={data} labels={tableLabels} />
      </div>
    </div>

    <HowItWorks locale={locale} />
    <Citation locale={locale} />
  </section>
</Base>
